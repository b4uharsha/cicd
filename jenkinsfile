pipeline {
    agent {
        docker {
            image 'ansible/ansible:2.12.0'  // Specify the Ansible container image version
            args '-v /path/to/credentials:/path/to/credentials'  // Bind mount for credentials if needed
        }
    }

    environment {
        GOOGLE_APPLICATION_CREDENTIALS = '/path/to/credentials/gcp-service-account.json'  // Path inside the container
        TERRAFORM_SA_KEY = '/path/to/credentials/terraform-sa-key.json'
    }

    stages {
        stage('Ansible Setup') {
            steps {
                script {
                    dir('ansible') {
                        // Install required Ansible collections from requirements.yml inside the container
                        sh 'ansible-galaxy install -r requirements.yml --force'
                    }
                }
            }
        }

        stage('List GCP Resources') {
            steps {
                script {
                    dir('ansible') {
                        // Run the Ansible playbook with the tag to list GCP resources
                        sh 'ansible-playbook -i inventory playbook.yml --tags "gcp_list_resources"'
                    }
                }
            }
        }

        stage('BigQuery Operations') {
            steps {
                script {
                    dir('ansible') {
                        // Run the Ansible playbook with the tag for BigQuery operations
                        sh 'ansible-playbook -i inventory playbook.yml --tags "bq_operations"'
                    }
                }
            }
        }
    }

    post {
        always {
            // Cleaning up workspace
            cleanWs()
        }

        success {
            echo 'Pipeline completed successfully.'
        }

        failure {
            echo 'Pipeline failed. Check the logs for details.'
        }
    }
}
